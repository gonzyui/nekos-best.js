{
    "name": "nekos-best.js",
    "version": "6.6.0",
    "author": "Thund (https://github.com/thund-x)",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/nekos-best/nekos-best.js.git"
    },
    "devDependencies": {
        "@types/node": "^22.19.17",
        "@vitest/coverage-v8": "^4.1.5",
        "esbuild": "^0.25.12",
        "typescript": "^5.9.3",
        "vitest": "^4.1.5"
    },
    "exports": {
        "import": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.mjs"
        },
        "require": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "bugs": "https://github.com/nekos-best/nekos-best.js/issues",
    "contributors": [
        "oriel-beck (https://github.com/oriel-beck)",
        "Thusuzzee (https://github.com/Thusuzzee)"
    ],
    "description": "The official JavaScript wrapper for the https://nekos.best API with TypeScript typings.",
    "engines": {
        "node": ">=22"
    },
    "files": [
        "dist"
    ],
    "keywords": [
        "nekos",
        "neko",
        "api",
        "wrapper",
        "roleplay",
        "rp"
    ],
    "license": "MIT",
    "scripts": {
        "build": "npm run build:cjs && npm run build:esm",
        "build:cjs": "esbuild src/index.ts --outfile=dist/index.js --platform=node --format=cjs --target=esnext --bundle",
        "build:esm": "esbuild src/index.ts --outfile=dist/index.mjs --platform=node --format=esm --target=esnext --bundle",
        "types": "tsc --emitDeclarationOnly",
        "prepack": "npm run build && npm run types",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts"
}